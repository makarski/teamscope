# teamscope configuration template.
# Copy to teamscope-config.toml and fill in credentials.

[jira]
user = "you@example.com"
base_url = "https://your-domain.atlassian.net"
token = "<jira-api-token>"
# Custom field id holding an epic's start date (optional).
start_date_field = "customfield_10015"
# JQL clause name for the start-date field, used in the epic filter.
# Defaults to "Start date[Date]" when omitted.
start_date_jql = "Start date[Date]"

  # Map raw Jira statuses onto delivery buckets.
  [jira.status_names]
  done = ["Done", "Closed", "Resolved"]
  progress = ["In Progress", "In Review"]
  todo = ["To Do", "Backlog", "Open"]

# GitHub is a secondary contribution signal. When configured, snapshot
# fetches merged PR and commit counts per repo (last 90 days) and shows
# them as activity badges on the dashboard and in the PO brief.
# Add github_repos to each team below to enable.
[github]
token = "<github-token>"

# Anthropic (or Bedrock, below) powers the classification fallback and
# alignment scoring. Omit both sections (or leave token/model empty) to run
# rules-only with no AI.
[anthropic]
base_url = "https://api.anthropic.com"
token = "<anthropic-api-key>"
model = "claude-3-5-haiku-latest"

# Bedrock is an alternative to [anthropic] for accounts that only have AWS
# access. When [bedrock] model is set, it takes priority over [anthropic].
# Auth uses the standard AWS credential chain (env vars, shared config
# profile, or an IAM role) -- no token goes here.
# [bedrock]
# region = "us-east-1"
# model = "anthropic.claude-3-5-haiku-20241022-v1:0"
# profile = "my-aws-profile"  # optional; defaults to the standard AWS chain

# Slack is optional; snapshot posts a summary per team when configured.
[slack]
token = "<slack-bot-token>"
channel = "#team-progress"

# --- Rubrics -----------------------------------------------------------------
# A rubric is the named set of criteria a team is measured against. Each active
# epic is mapped to the criterion it best serves, and (with AI) judged on
# whether it advances that criterion.
#
# source = "static"      criteria are listed inline (see [[rubrics.criteria]])
# source = "jira_label"  criteria are the epics carrying `label` in
#                        `label_project` -- one criterion per epic, fully
#                        automated from Jira with no AI.

# Example 1: a classic work-type split, defined inline.
[[rubrics]]
name = "work"
source = "static"

  [[rubrics.criteria]]
  key = "business"
  title = "Customer / revenue value"
  lens = "business"

  [[rubrics.criteria]]
  key = "chore"
  title = "Maintenance and tech debt"
  lens = "operations"

  [[rubrics.criteria]]
  key = "rnd"
  title = "Research and experiments"
  lens = "product"

  # Keyword hints steer the deterministic rule engine (labels and components
  # matching a criterion key always win first). Text-only fallback below.
  [[rubrics.keyword_hints]]
  keyword = "billing"
  criterion = "business"
  [[rubrics.keyword_hints]]
  keyword = "refactor"
  criterion = "chore"
  [[rubrics.keyword_hints]]
  keyword = "spike"
  criterion = "rnd"

# Example 2: a readiness rubric sourced from Jira labels. Every epic in
# `label_project` carrying `label` becomes one criterion.
[[rubrics]]
name = "readiness"
source = "jira_label"
label = "product-readiness"
label_project = "PT"
lens = "product"

# Where snapshots are persisted.
[store]
path = "teamscope.db"

[[teams]]
name = "Payments"
jira_projects = ["PT"]
github_repos = ["your-org/payments"]
rubric = "readiness"

[[teams]]
name = "Platform"
jira_projects = ["PLAT"]
github_repos = ["your-org/platform"]
rubric = "work"
